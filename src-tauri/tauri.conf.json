{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remnus",
  "identifier": "com.remnus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["remnus"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/Ranork/remnus-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2NDBBQjNCMzlDMzE5NEQKUldSTkdjTTVPNnRBaGxzSDRQQlFlVXZvdGxTUWlpTWczVXcxeXNhaVRPcmUrSEp2YUh0NEZPWnIK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Customizable databases and pages",
    "longDescription": "Remnus is a Notion-like workspace with customizable databases and pages."
  }
}
