  "scripts": {
    "dev": "next dev",
    "build": "npx tsx src/db/migrate.ts && npm run db:seed && next build",
    "start": "next start",
    "test": "npx tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint",
    "db:migrate": "npx tsx src/db/migrate.ts",
    "db:setup": "npx tsx src/db/setup.ts",
    "db:seed": "npx tsx scripts/seed-mcp-docs.ts && npx tsx scripts/seed-blog.ts",
